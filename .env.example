# ─── Configurações do site Galpão do Aço ────────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores.
# No Vercel: configure as variáveis em Settings > Environment Variables

# URL base da API de Produtos (sem barra final)
# Exemplo: https://api.galpaodoaco.com.br
NEXT_PUBLIC_API_URL=http://127.0.0.1:8050/api

# Número do WhatsApp para receber pedidos (com código do país + DDD)
# Exemplo: 559532240115
NEXT_PUBLIC_WHATSAPP=559532240115

# Google Analytics 4 - ID de medicao
# Exemplo: G-AB12CD34EF
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag global para Google Ads/GA4
# Exemplo: G-AB12CD34EF ou AW-123456789
NEXT_PUBLIC_GOOGLE_TAG_ID=

# Meta Pixel - ID numerico do pixel
# Exemplo: 123456789012345
NEXT_PUBLIC_META_PIXEL_ID=

# URL publica do site usada em sitemap e schema
NEXT_PUBLIC_SITE_URL=https://www.galpaodoaco.com

# Chave da OpenAI para a pagina /mkt gerar anuncios com IA
# Exemplo: sk-...
OPENAI_API_KEY=

# Modelo usado no endpoint interno /api/mkt/generate
# Exemplo: gpt-image-1
OPENAI_MKT_MODEL=gpt-image-1
